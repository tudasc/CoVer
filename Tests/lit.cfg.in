import lit.formats

config.binaries = "@COVER_INSTALLED_BINARIES_DIR@"
config.test_format = lit.formats.ShTest("0")
config.suffixes = {".c", ".F90", ".f90"}

config.substitutions += [
    ("%binaries", config.binaries),
    ("%clangContracts", config.binaries + "/clangContracts"),
    ("%flangContracts", config.binaries + ("/flangContracts" if not "NO_TS29113" in os.environ else "/flangContracts-no-ts")),
    ("%run_common", "--predefined-contracts --instrument-contracts %s -o %t.exe 2>&1 | tee %t.test_out && (COVER_COVERAGE_FOLDER='%t_coverage' mpiexec -np 2 %t.exe >> %t.test_out 2>&1 || true) && FileCheck %s < %t.test_out")
]

config.environment["OMPI_CC"] = "clang"
config.environment["OMPI_FC"] = "flang"

for var in ['OMPI_CC', 'OMPI_CXX', 'OMPI_FC', 'MPICH_CC', 'MPICH_CXX', 'MPICH_FC',
            'COVER_WRAP_TARGET_mpicc', 'COVER_WRAP_TARGET_mpicxx', 'COVER_WRAP_TARGET_mpifort',
            'OMPI_ALLOW_RUN_AS_ROOT', 'OMPI_ALLOW_RUN_AS_ROOT_CONFIRM']: # For Docker testing
    if var in os.environ: config.environment[var] = os.environ[var]

config.name = "test-suite"
